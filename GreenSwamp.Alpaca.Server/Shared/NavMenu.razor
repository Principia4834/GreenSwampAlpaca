@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudNavMenu>

    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>

    @foreach (var device in ASCOM.Alpaca.DeviceManager.Cameras)
    {
        <MudNavLink Href="@($"/setup/v1/Camera/{device.Key}/setup")" Icon="@Icons.Material.Filled.PhotoCamera">
            Camera @device.Key
        </MudNavLink>
    }
    @foreach (var device in ASCOM.Alpaca.DeviceManager.CoverCalibrators)
    {
        <MudNavLink Href="@($"/setup/v1/covercalibrator/{device.Key}/setup")" Icon="@Icons.Material.Filled.Contrast">
            CoverCalibrator @device.Key
        </MudNavLink>
    }
    @foreach (var device in ASCOM.Alpaca.DeviceManager.Domes)
    {
        <MudNavLink Href="@($"/setup/v1/dome/{device.Key}/setup")" Icon="@Icons.Material.Filled.Circle">
            Dome @device.Key
        </MudNavLink>
    }
    @foreach (var device in ASCOM.Alpaca.DeviceManager.FilterWheels)
    {
        <MudNavLink Href="@($"/setup/v1/filterwheel/{device.Key}/setup")" Icon="@Icons.Material.Filled.FilterCenterFocus">
            Filter Wheel @device.Key
        </MudNavLink>
    }
    @foreach (var device in ASCOM.Alpaca.DeviceManager.Focusers)
    {
        <MudNavLink Href="@($"/setup/v1/focuser/{device.Key}/setup")" Icon="@Icons.Material.Filled.Adjust">
            Focuser @device.Key
        </MudNavLink>
    }
    @foreach (var device in ASCOM.Alpaca.DeviceManager.ObservingConditions)
    {
        <MudNavLink Href="@($"/setup/v1/ObservingConditions/{device.Key}/setup")" Icon="@Icons.Material.Filled.Cloud">
            ObservingConditions @device.Key
        </MudNavLink>
    }
    @foreach (var device in ASCOM.Alpaca.DeviceManager.Rotators)
    {
        <MudNavLink Href="@($"/setup/v1/rotator/{device.Key}/setup")" Icon="@Icons.Material.Filled.RotateRight">
            Rotator @device.Key
        </MudNavLink>
    }
    @foreach (var device in ASCOM.Alpaca.DeviceManager.SafetyMonitors)
    {
        <MudNavLink Href="@($"/setup/v1/SafetyMonitor/{device.Key}/setup")" Icon="@Icons.Material.Filled.Shield">
            SafetyMonitor @device.Key
        </MudNavLink>
    }
    @foreach (var device in ASCOM.Alpaca.DeviceManager.Switches)
    {
        <MudNavLink Href="@($"/setup/v1/switch/{device.Key}/setup")" Icon="@Icons.Material.Filled.ToggleOn">
            Switch @device.Key
        </MudNavLink>
    }
    <MudNavLink Href="/mount-control" Icon="@Icons.Material.Filled.Navigation">Control</MudNavLink>
    <MudNavLink Href="/mount-status" Icon="@Icons.Material.Filled.DisplaySettings">Status</MudNavLink>
    <MudNavLink Href="/mount-settings" Icon="@Icons.Material.Filled.TravelExplore">Settings</MudNavLink>
    <MudNavLink Href="/monitor" Icon="@Icons.Material.Filled.ListAlt">Monitor</MudNavLink>

    <MudDivider Class="my-2" />

    @foreach (var device in ASCOM.Alpaca.DeviceManager.Telescopes)
    {
        <MudNavLink Icon="@Icons.Material.Filled.ShowChart"
                    OnClick="@(() => OpenChartWindowAsync($"/charts/radec/{device.Key}", $"gs-radec-chart-{device.Key}"))">
            RA/Dec Chart @device.Key
        </MudNavLink>
        <MudNavLink Icon="@Icons.Material.Filled.DataUsage"
                    OnClick="@(() => OpenChartWindowAsync($"/charts/pulse/{device.Key}", $"gs-pulse-chart-{device.Key}"))">
            Pulse Chart @device.Key
        </MudNavLink>
    }

    <MudDivider Class="my-2" />

    <MudNavLink Href="/settings-explorer" Icon="@Icons.Material.Filled.AccountTree">Settings Explorer</MudNavLink>
    <MudNavLink Href="/setup" Icon="@Icons.Material.Filled.Settings">Alpaca Settings</MudNavLink>
    <MudNavLink Href="/check-settings" Icon="@Icons.Material.Filled.MonitorHeart">Check Settings</MudNavLink>
</MudNavMenu>

@code {
    private async Task OpenChartWindowAsync(string url, string windowKey)
    {
        await JS.InvokeVoidAsync(
            "chartWindowInterop.open",
            DotNetObjectReference.Create(this),
            url,
            windowKey,
            1200,
            700);
    }

    [JSInvokable]
    public void OnPopupBlocked(string url)
    {
        Snackbar.Add(
            "Chart window was blocked. Please allow pop-ups for this site.",
            Severity.Warning);
    }

    [JSInvokable]
    public void OnChartWindowClosed(string windowKey)
    {
        // Chart window closed externally — no nav-menu state to update.
    }
}
