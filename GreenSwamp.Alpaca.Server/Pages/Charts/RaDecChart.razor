@page "/charts/radec/{DeviceNumber:int}"
@layout ChartWindowLayout
@using ApexCharts
@using Microsoft.AspNetCore.SignalR.Client

@inject IVersionedSettingsService SettingsService
@inject ChartLoggingService Logger
@inject TelescopeStateService StateService
@inject IJSRuntime JS
@inject NavigationManager Nav

@implements IAsyncDisposable

<PageTitle>RA / Dec Chart — GS Alpaca</PageTitle>

<div style="display:flex;flex-direction:column;height:100vh;overflow:hidden;padding:8px;box-sizing:border-box;">

    @* -- Toolbar ----------------------------------------------------------- *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2" Wrap="Wrap.Wrap">

        <MudText Typo="Typo.subtitle1" Style="white-space:nowrap;">
                <b style="color:var(--gs-accent-500);">RA / Dec</b> Position &mdash; Device @DeviceNumber
            </MudText>

        <MudSpacer />

        @if (_hubState != HubConnectionState.Connected)
        {
            <MudChip T="string" Color="MudBlazor.Color.Warning" Size="MudBlazor.Size.Small" Icon="@Icons.Material.Filled.SignalWifiOff">
                @(_hubState == HubConnectionState.Reconnecting ? "Reconnecting…" : "Disconnected")
            </MudChip>
        }

        <MudSelect T="string" Label="Scale" Value="@_settings.RaDecScale"
                   ValueChanged="@OnScaleChangedAsync"
                   Variant="Variant.Outlined" Margin="Margin.Dense"
                   Style="min-width:130px;">
            <MudSelectItem Value="@("Steps")">Steps</MudSelectItem>
            <MudSelectItem Value="@("Degrees")">Degrees</MudSelectItem>
            <MudSelectItem Value="@("ArcSeconds")">Arc-seconds</MudSelectItem>
        </MudSelect>

        <MudSwitch T="bool" Label="Axis 1" Value="@_settings.ShowAxis1"
                   ValueChanged="@(v => OnSeriesToggleAsync(v, axis: 1))"
                   Color="MudBlazor.Color.Error" />

        <MudSwitch T="bool" Label="Axis 2" Value="@_settings.ShowAxis2"
                   ValueChanged="@(v => OnSeriesToggleAsync(v, axis: 2))"
                   Color="MudBlazor.Color.Info" />

        <MudTooltip Text="@(_loggingActive ? "Stop logging" : "Start logging")" Placement="Placement.Left">
            <MudIconButton Icon="@(_loggingActive ? Icons.Material.Filled.Stop : Icons.Material.Filled.FiberManualRecord)"
                           Color="@(_loggingActive ? MudBlazor.Color.Error : MudBlazor.Color.Default)"
                           OnClick="ToggleLoggingAsync" Size="MudBlazor.Size.Small" />
        </MudTooltip>

        <MudTooltip Text="Export chart" Placement="Placement.Left">
            <MudMenu Icon="@Icons.Material.Filled.Download"
                     Size="MudBlazor.Size.Small"
                     AnchorOrigin="Origin.BottomRight"
                     TransformOrigin="Origin.TopRight"
                     Dense="true"
                     AriaLabel="Export chart">
                <MudMenuItem Icon="@Icons.Material.Filled.Image" OnClick="ExportPngAsync">Export PNG</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.TableChart" OnClick="ExportCsvAsync">Export CSV</MudMenuItem>
            </MudMenu>
        </MudTooltip>

        <MudTooltip Text="Clear chart" Placement="Placement.Left">
            <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep"
                           OnClick="ClearChartAsync" Size="MudBlazor.Size.Small" />
        </MudTooltip>

    </MudStack>

    @* -- Chart ------------------------------------------------------------- *@
    <div style="flex:1;min-height:0;">
        <ErrorBoundary>
            <ChildContent>
        @if (_axis1Data.Count > 0 || _axis2Data.Count > 0 || _ready)
        {
            <ApexChart TItem="ChartPointDto"
                       @key="@_settings.RaDecScale"
                       Title=""
                       Options="@_chartOptions"
                       @ref="_chart"
                       Height="@("100%")"
                       Width="@("100%")">

                @if (_settings.ShowAxis1)
                {
                    <ApexPointSeries TItem="ChartPointDto"
                                     Items="@_axis1Data"
                                     Name="Axis 1"
                                     SeriesType="SeriesType.Line"
                                     XValue="@(p => p.TimestampMs)"
                                     YValue="@(p => (decimal)GetValue(p, 0))"
                                     Color="#b71c1c" />
                }

                @if (_settings.ShowAxis2)
                {
                    <ApexPointSeries TItem="ChartPointDto"
                                     Items="@_axis2Data"
                                     Name="Axis 2"
                                     SeriesType="SeriesType.Line"
                                     XValue="@(p => p.TimestampMs)"
                                     YValue="@(p => (decimal)GetValue(p, 1))"
                                     Color="#2196f3" />
                }

            </ApexChart>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="MudBlazor.Color.Secondary" Class="pa-4">
                Waiting for mount data…
            </MudText>
        }
            </ChildContent>
            <ErrorContent>
                <MudAlert Severity="Severity.Error" Class="ma-2">
                    Chart failed to render. Please close and reopen this window.
                </MudAlert>
            </ErrorContent>
        </ErrorBoundary>
    </div>

</div>
