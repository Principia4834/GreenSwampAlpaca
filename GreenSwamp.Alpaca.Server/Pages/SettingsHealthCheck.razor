@page "/settings-health"
@using GreenSwamp.Alpaca.Server.Components

<PageTitle>Settings Health Check</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2>Settings Health Check</h2>
            <p class="text-muted">
                Validate and repair your settings configuration. This tool checks the integrity of your settings file
                and can automatically fix common configuration issues.
            </p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-10 col-xl-8">
            <SettingsHealthStatus />
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-10 col-xl-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <span class="oi oi-info me-2" aria-hidden="true"></span>
                        About Settings Validation
                    </h5>
                </div>
                <div class="card-body">
                    <h6>What is validated?</h6>
                    <ul>
                        <li><strong>File-level checks:</strong> File existence, read permissions, JSON syntax, required structure</li>
                        <li><strong>Device validation:</strong> DeviceNumber uniqueness, DeviceName required, AlignmentMode valid, Mount type valid</li>
                        <li><strong>Synchronization:</strong> Devices and AlpacaDevices arrays must be in sync</li>
                    </ul>

                    <h6 class="mt-3">Automatic Repair Actions</h6>
                    <p>The repair function can automatically fix:</p>
                    <ul>
                        <li>Missing or corrupted Devices array (regenerates from defaults)</li>
                        <li>Missing device names (generates "Telescope X" names)</li>
                        <li>Invalid AlignmentMode values (resets to GermanPolar)</li>
                        <li>Missing Mount values (sets to Simulator)</li>
                        <li>Out-of-sync AlpacaDevices array (regenerates from Devices)</li>
                    </ul>

                    <h6 class="mt-3">Safety Features</h6>
                    <ul>
                        <li><strong>Automatic backup:</strong> A timestamped backup is created before any changes</li>
                        <li><strong>Validation after repair:</strong> Changes are validated before saving</li>
                        <li><strong>Restore on failure:</strong> Settings are restored from backup if repair fails</li>
                        <li><strong>Quarantine:</strong> Invalid devices are excluded from the active device list</li>
                    </ul>

                    <h6 class="mt-3">Manual Repair</h6>
                    <p>For issues that cannot be automatically fixed:</p>
                    <ol>
                        <li>Use the <strong>Open Settings Folder</strong> button above</li>
                        <li>Edit <code>appsettings.user.json</code> in a text editor</li>
                        <li>Restart the application</li>
                        <li>If needed, delete the file to regenerate default settings</li>
                    </ol>

                    <div class="alert alert-info mb-0 mt-3">
                        <strong>Note:</strong> This validation runs automatically during application startup.
                        Invalid devices are quarantined and not advertised to ASCOM clients.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
