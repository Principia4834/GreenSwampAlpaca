@page "/profiles/{ProfileName}/edit"
@page "/profiles/new"
@using GreenSwamp.Alpaca.Settings.Services
@using GreenSwamp.Alpaca.Settings.Models
@inject ISettingsProfileService ProfileService
@inject NavigationManager Navigation
@inject ILogger<ProfileEditor> Logger

<PageTitle>@(IsNewProfile ? "Create Profile" : $"Edit Profile: {ProfileName}")</PageTitle>

<h3>@(IsNewProfile ? "Create New Profile" : $"Edit Profile: {ProfileName}")</h3>

<div class="container-fluid mt-4">
    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error:</strong> @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(validationMessage))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <strong>Validation Issue:</strong> @validationMessage
            <button type="button" class="btn-close" @onclick="@(() => validationMessage = null)"></button>
        </div>
    }

    @if (loading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading profile...</p>
        </div>
    }
    else if (profile != null)
    {
        <EditForm Model="@profile" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />
            
            <!-- Basic Information -->
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">Basic Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="profileName" class="form-label">Profile Name <span class="text-danger">*</span></label>
                                <InputText id="profileName" class="form-control" @bind-Value="profile.Name" disabled="@(!IsNewProfile)" />
                                <div class="form-text">Unique identifier for this profile.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="displayName" class="form-label">Display Name <span class="text-danger">*</span></label>
                                <InputText id="displayName" class="form-control" @bind-Value="profile.DisplayName" />
                                <div class="form-text">Human-readable name shown in UI.</div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <InputTextArea id="description" class="form-control" rows="2" @bind-Value="profile.Description" />
                        <div class="form-text">Optional description of this profile.</div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="alignmentMode" class="form-label">Alignment Mode <span class="text-danger">*</span></label>
                                <InputSelect id="alignmentMode" class="form-select" @bind-Value="profile.AlignmentMode">
                                    <option value="@AlignmentMode.AltAz">AltAz</option>
                                    <option value="@AlignmentMode.Polar">Polar</option>
                                    <option value="@AlignmentMode.GermanPolar">German Polar</option>
                                </InputSelect>
                                <div class="form-text">Mount alignment and tracking mode.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="mountType" class="form-label">Mount Type <span class="text-danger">*</span></label>
                                <InputText id="mountType" class="form-control" @bind-Value="profile.Settings.Mount" />
                                <div class="form-text">E.g., Simulator, SkyWatcher, Celestron.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Location -->
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">Location</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label for="latitude" class="form-label">Latitude (°) <span class="text-danger">*</span></label>
                                <InputNumber id="latitude" class="form-control" @bind-Value="profile.Settings.Latitude" />
                                <div class="form-text">Range: -90 to 90</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label for="longitude" class="form-label">Longitude (°) <span class="text-danger">*</span></label>
                                <InputNumber id="longitude" class="form-control" @bind-Value="profile.Settings.Longitude" />
                                <div class="form-text">Range: -180 to 180</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label for="elevation" class="form-label">Elevation (m)</label>
                                <InputNumber id="elevation" class="form-control" @bind-Value="profile.Settings.Elevation" />
                                <div class="form-text">Meters above sea level.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Hardware Configuration (Physical Mounts Only) -->
            @if (profile.Settings.Mount != "Simulator")
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <h5 class="mb-0">Hardware Configuration</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="port" class="form-label">Serial Port <span class="text-danger">*</span></label>
                                    <InputText id="port" class="form-control" @bind-Value="profile.Settings.Port" placeholder="COM3" />
                                    <div class="form-text">COM port for mount connection.</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="baudRate" class="form-label">Baud Rate <span class="text-danger">*</span></label>
                                    <InputNumber id="baudRate" class="form-control" @bind-Value="profile.Settings.BaudRate" />
                                    <div class="form-text">Typical: 9600, 19200, 115200</div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="dataBits" class="form-label">Data Bits</label>
                                    <InputNumber id="dataBits" class="form-control" @bind-Value="profile.Settings.DataBits" />
                                    <div class="form-text">Typical: 8</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="dtrEnable" class="form-label">DTR Enable</label>
                                    <InputCheckbox id="dtrEnable" class="form-check-input" @bind-Value="profile.Settings.DTREnable" />
                                    <div class="form-text">Data Terminal Ready signal.</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="handshake" class="form-label">Handshake</label>
                                    <InputText id="handshake" class="form-control" @bind-Value="profile.Settings.Handshake" />
                                    <div class="form-text">None, XOnXOff, RequestToSend</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Tracking Configuration -->
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">Tracking Configuration</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3 form-check">
                                <InputCheckbox id="autoTrack" class="form-check-input" @bind-Value="profile.Settings.AutoTrack" />
                                <label class="form-check-label" for="autoTrack">
                                    Auto Track
                                </label>
                                <div class="form-text">Enable automatic sidereal tracking.</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label for="siderealRate" class="form-label">Sidereal Rate (°/hour)</label>
                                <InputNumber id="siderealRate" class="form-control" @bind-Value="profile.Settings.SiderealRate" />
                                <div class="form-text">Default: 15.0410671787</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3 form-check">
                                <InputCheckbox id="refraction" class="form-check-input" @bind-Value="profile.Settings.Refraction" />
                                <label class="form-check-label" for="refraction">
                                    Refraction Correction
                                </label>
                                <div class="form-text">Apply atmospheric refraction.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Guiding -->
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">Guiding</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="guideRateX" class="form-label">Guide Rate Offset X</label>
                                <InputNumber id="guideRateX" class="form-control" @bind-Value="profile.Settings.GuideRateOffsetX" />
                                <div class="form-text">RA guide rate adjustment.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="guideRateY" class="form-label">Guide Rate Offset Y</label>
                                <InputNumber id="guideRateY" class="form-control" @bind-Value="profile.Settings.GuideRateOffsetY" />
                                <div class="form-text">Dec guide rate adjustment.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Optics -->
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">Optics</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="apertureDiameter" class="form-label">Aperture Diameter (m)</label>
                                <InputNumber id="apertureDiameter" class="form-control" @bind-Value="profile.Settings.ApertureDiameter" />
                                <div class="form-text">Telescope aperture in meters.</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="focalLength" class="form-label">Focal Length (m)</label>
                                <InputNumber id="focalLength" class="form-control" @bind-Value="profile.Settings.FocalLength" />
                                <div class="form-text">Telescope focal length in meters.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <button type="button" class="btn btn-secondary" @onclick="Cancel">
                            <span class="oi oi-x"></span> Cancel
                        </button>
                        <div>
                            <button type="button" class="btn btn-info me-2" @onclick="ValidateOnly">
                                <span class="oi oi-check"></span> Validate
                            </button>
                            <button type="submit" class="btn btn-success" disabled="@saving">
                                @if (saving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                else
                                {
                                    <span class="oi oi-circle-check me-2"></span>
                                }
                                @(IsNewProfile ? "Create Profile" : "Save Changes")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public string? ProfileName { get; set; }

    private SettingsProfile? profile;
    private bool loading = true;
    private bool saving = false;
    private string? errorMessage;
    private string? validationMessage;

    private bool IsNewProfile => string.IsNullOrWhiteSpace(ProfileName) || ProfileName == "new";

    protected override async Task OnInitializedAsync()
    {
        await LoadProfile();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadProfile();
    }

    private async Task LoadProfile()
    {
        try
        {
            loading = true;
            errorMessage = null;

            if (IsNewProfile)
            {
                // Create new profile with defaults
                profile = new SettingsProfile
                {
                    Name = "new-profile",
                    DisplayName = "New Profile",
                    Description = "New profile configuration",
                    AlignmentMode = AlignmentMode.AltAz,
                    Settings = new SkySettings
                    {
                        Mount = "Simulator",
                        AlignmentMode = "AltAz",
                        Latitude = 51.21135,
                        Longitude = -1.459816,
                        Elevation = 10.0,
                        Port = "COM3",
                        BaudRate = 9600,
                        DataBits = 8,
                        DTREnable = false,
                        Handshake = "None",
                        AutoTrack = true,
                        SiderealRate = 15.0410671787,
                        Refraction = true,
                        GuideRateOffsetX = 0.5,
                        GuideRateOffsetY = 0.5,
                        ApertureDiameter = 0.203,
                        FocalLength = 1.0
                    },
                    IsReadOnly = false,
                    Created = DateTime.UtcNow,
                    LastModified = DateTime.UtcNow
                };
            }
            else
            {
                profile = await ProfileService.GetProfileAsync(ProfileName!);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load profile {ProfileName}", ProfileName);
            errorMessage = $"Failed to load profile: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        if (profile == null) return;

        try
        {
            saving = true;
            errorMessage = null;
            validationMessage = null;

            // Validate first
            var validation = await ProfileService.ValidateProfileAsync(profile);
            if (!validation.IsValid)
            {
                validationMessage = validation.ErrorMessage;
                return;
            }

            // Save profile
            if (IsNewProfile)
            {
                await ProfileService.CreateProfileAsync(profile.Name, profile.AlignmentMode);
                var created = await ProfileService.GetProfileAsync(profile.Name);
                created.DisplayName = profile.DisplayName;
                created.Description = profile.Description;
                created.Settings = profile.Settings;
                await ProfileService.UpdateProfileAsync(created);
            }
            else
            {
                await ProfileService.UpdateProfileAsync(profile);
            }

            // Navigate back to browser
            Navigation.NavigateTo("/profiles");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save profile {ProfileName}", profile?.Name);
            errorMessage = $"Failed to save profile: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ValidateOnly()
    {
        if (profile == null) return;

        try
        {
            validationMessage = null;
            var validation = await ProfileService.ValidateProfileAsync(profile);

            if (validation.IsValid)
            {
                errorMessage = null;
                // Show success - profile is valid
                validationMessage = "✓ Profile validation passed successfully.";
            }
            else
            {
                validationMessage = validation.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to validate profile");
            errorMessage = $"Validation failed: {ex.Message}";
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/profiles");
    }
}
