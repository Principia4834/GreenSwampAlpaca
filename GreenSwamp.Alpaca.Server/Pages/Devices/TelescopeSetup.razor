@page "/setup/v1/Telescope/{InstanceID:int}/setup"
@using GreenSwamp.Alpaca.MountControl
@using GreenSwamp.Alpaca.Shared

<PageTitle>Telescope Setup - Device @InstanceID</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Telescope Setup: Device @InstanceID</MudText>

@if (ASCOM.Alpaca.DeviceManager.Telescopes.ContainsKey(InstanceID))
{
    var instance = MountRegistry.GetInstance(InstanceID);
    if (instance != null)
    {
        var settings = instance.Settings;

        <MudGrid Spacing="3" Class="mb-4">

            @* ── Device Information ───────────────────────────────────── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" />
                                <MudText Typo="Typo.h6">Device Information</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSimpleTable Dense="true" Hover="true">
                            <tbody>
                                <tr><th>Device Number</th><td><MudChip T="string" Size="Size.Small" Color="Color.Default">@InstanceID</MudChip></td></tr>
                                <tr><th>Device Name</th><td><strong>@instance.DeviceName</strong></td></tr>
                                <tr><th>Mount Type</th><td>@settings.Mount</td></tr>
                                <tr><th>Alignment Mode</th><td><MudChip T="string" Size="Size.Small" Color="Color.Info">@settings.AlignmentMode</MudChip></td></tr>
                                <tr>
                                    <th>Connection Status</th>
                                    <td>
                                        @if (instance.IsConnected)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Check">Connected</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Disconnected</MudChip>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* ── Location Settings ────────────────────────────────────── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Success" />
                                <MudText Typo="Typo.h6">Location Settings</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSimpleTable Dense="true" Hover="true">
                            <tbody>
                                <tr><th>Latitude</th><td>@settings.Latitude.ToString("F6")°</td></tr>
                                <tr><th>Longitude</th><td>@settings.Longitude.ToString("F6")°</td></tr>
                                <tr><th>Elevation</th><td>@settings.Elevation m</td></tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* ── Serial Port Settings ─────────────────────────────────── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.SettingsInputHdmi" Color="Color.Warning" />
                                <MudText Typo="Typo.h6">Serial Port Settings</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSimpleTable Dense="true" Hover="true">
                            <tbody>
                                <tr><th>Port</th><td><code>@settings.Port</code></td></tr>
                                <tr><th>Baud Rate</th><td>@settings.BaudRate</td></tr>
                                <tr><th>Data Bits</th><td>@settings.DataBits</td></tr>
                                <tr><th>Read Timeout</th><td>@settings.ReadTimeout ms</td></tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* ── Tracking Settings ────────────────────────────────────── *@
            <MudItem xs="12" md="6">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.TrackChanges" Color="Color.Info" />
                                <MudText Typo="Typo.h6">Tracking Settings</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSimpleTable Dense="true" Hover="true">
                            <tbody>
                                <tr>
                                    <th>Auto Track</th>
                                    <td>
                                        <MudChip T="string" Size="Size.Small" Color="@(settings.AutoTrack ? Color.Success : Color.Default)">
                                            @(settings.AutoTrack ? "Enabled" : "Disabled")
                                        </MudChip>
                                    </td>
                                </tr>
                                <tr><th>Tracking Rate</th><td>@settings.TrackingRate</td></tr>
                                <tr><th>Sidereal Rate</th><td>@settings.SiderealRate.ToString("F7")°/sec</td></tr>
                                <tr>
                                    <th>Refraction</th>
                                    <td>
                                        <MudChip T="string" Size="Size.Small" Color="@(settings.Refraction ? Color.Success : Color.Default)">
                                            @(settings.Refraction ? "Enabled" : "Disabled")
                                        </MudChip>
                                    </td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* ── Telescope Specifications ─────────────────────────────── *@
            <MudItem xs="12">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Visibility" />
                                <MudText Typo="Typo.h6">Telescope Specifications</MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <MudSimpleTable Dense="true" Hover="true">
                                    <tbody>
                                        <tr><th>Aperture Diameter</th><td>@settings.ApertureDiameter m</td></tr>
                                        <tr><th>Aperture Area</th><td>@settings.ApertureArea m²</td></tr>
                                        <tr><th>Focal Length</th><td>@settings.FocalLength m</td></tr>
                                    </tbody>
                                </MudSimpleTable>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSimpleTable Dense="true" Hover="true">
                                    <tbody>
                                        <tr><th>RA Backlash</th><td>@settings.RaBacklash</td></tr>
                                        <tr><th>Dec Backlash</th><td>@settings.DecBacklash</td></tr>
                                    </tbody>
                                </MudSimpleTable>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSimpleTable Dense="true" Hover="true">
                                    <tbody>
                                        <tr><th>Min Pulse RA</th><td>@settings.MinPulseRa ms</td></tr>
                                        <tr><th>Min Pulse Dec</th><td>@settings.MinPulseDec ms</td></tr>
                                    </tbody>
                                </MudSimpleTable>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        <MudAlert Severity="Severity.Success" Class="mb-3">
            Profile loaded successfully. Each device has its own alignment mode and configuration.
            <strong>Alignment Mode: @settings.AlignmentMode</strong>
        </MudAlert>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack"
                   Href="/device-manager">Back to Device Manager</MudButton>
    }
    else
    {
        <MudAlert Severity="Severity.Error" Class="mb-3">
            <MudText Typo="Typo.h6">Device Instance Not Found</MudText>
            Device @InstanceID is registered but has no Mount instance. This may indicate a configuration error.
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ArrowBack"
                   Href="/device-manager">Back to Device Manager</MudButton>
    }
}
else
{
    <MudAlert Severity="Severity.Warning" Class="mb-3">
        <MudText Typo="Typo.h6">Device Not Found</MudText>
        Device @InstanceID does not exist in the system. Please return to the Device Manager to see available devices.
    </MudAlert>
    <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/device-manager">Back to Device Manager</MudButton>
}

@code {
    [Parameter]
    public int InstanceID { get; set; }
}
