@page "/profiles"
@using GreenSwamp.Alpaca.Settings.Services
@using GreenSwamp.Alpaca.Settings.Models
@using System.Text.Json
@inject ISettingsProfileService ProfileService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ILogger<ProfileBrowser> Logger

<PageTitle>Profile Management</PageTitle>

<h3>Profile Management</h3>

<div class="container-fluid mt-4">
    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }

    @if (successMessage != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" @onclick="@(() => successMessage = null)"></button>
        </div>
    }

    <!-- Search and Filter Section -->
    <div class="card mb-4">
        <div class="card-header">
            <div class="row align-items-center">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text"><span class="oi oi-magnifying-glass"></span></span>
                        <input type="text" class="form-control" placeholder="Search profiles..." @bind="searchText" @bind:event="oninput" @onkeyup="FilterProfiles" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="filterAlignmentMode" @bind:after="FilterProfiles">
                        <option value="">All Alignment Modes</option>
                        <option value="AltAz">AltAz</option>
                        <option value="Polar">Polar</option>
                        <option value="GermanPolar">German Polar</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="filterInUse" @bind:after="FilterProfiles">
                        <option value="">All Profiles</option>
                        <option value="true">In Use</option>
                        <option value="false">Available</option>
                    </select>
                </div>
                <div class="col-md-3 text-end">
                    <button class="btn btn-success" @onclick="CreateNewProfile">
                        <span class="oi oi-plus"></span> New Profile
                    </button>
                    <button class="btn btn-secondary" @onclick="RefreshProfiles">
                        <span class="oi oi-reload"></span> Refresh
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Profile Grid -->
    <div class="row">
        @if (loading)
        {
            <div class="col-12 text-center">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2">Loading profiles...</p>
            </div>
        }
        else if (filteredProfiles == null || !filteredProfiles.Any())
        {
            <div class="col-12">
                <div class="alert alert-info">
                    <span class="oi oi-info"></span> No profiles found. 
                    @if (!string.IsNullOrWhiteSpace(searchText) || !string.IsNullOrWhiteSpace(filterAlignmentMode) || !string.IsNullOrWhiteSpace(filterInUse))
                    {
                        <text>Try adjusting your search filters.</text>
                    }
                    else
                    {
                        <text>Click "New Profile" to create one.</text>
                    }
                </div>
            </div>
        }
        else
        {
            @foreach (var profile in filteredProfiles)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 @(profile.InUse ? "border-success" : "")">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">@profile.DisplayName</h6>
                            @if (profile.InUse)
                            {
                                <span class="badge bg-success">In Use</span>
                            }
                            @if (profile.IsReadOnly)
                            {
                                <span class="badge bg-secondary">Read-Only</span>
                            }
                        </div>
                        <div class="card-body">
                            <p class="text-muted small mb-2">@profile.Name</p>
                            @if (!string.IsNullOrWhiteSpace(profile.Description))
                            {
                                <p class="small mb-2">@profile.Description</p>
                            }
                            <ul class="list-unstyled small mb-0">
                                <li><strong>Alignment:</strong> @profile.AlignmentMode</li>
                                <li><strong>Mount:</strong> @profile.Settings.Mount</li>
                                <li><strong>Location:</strong> @profile.Settings.Latitude.ToString("F5")°, @profile.Settings.Longitude.ToString("F5")°</li>
                                <li><strong>Modified:</strong> @profile.LastModified.ToString("g")</li>
                                @if (profile.InUse && profile.Devices.Any())
                                {
                                    <li><strong>Used by:</strong> Device @string.Join(", ", profile.Devices)</li>
                                }
                            </ul>
                        </div>
                        <div class="card-footer">
                            <div class="btn-group btn-group-sm w-100" role="group">
                                <button class="btn btn-outline-primary" @onclick="() => ViewProfile(profile.Name)" title="View Details">
                                    <span class="oi oi-eye"></span> View
                                </button>
                                <button class="btn btn-outline-secondary" @onclick="() => EditProfile(profile.Name)" title="Edit Profile" disabled="@profile.IsReadOnly">
                                    <span class="oi oi-pencil"></span> Edit
                                </button>
                                <button class="btn btn-outline-info" @onclick="() => DuplicateProfile(profile.Name)" title="Duplicate Profile">
                                    <span class="oi oi-document"></span> Copy
                                </button>
                                <button class="btn btn-outline-success" @onclick="() => ExportProfile(profile.Name)" title="Export Profile">
                                    <span class="oi oi-data-transfer-download"></span> Export
                                </button>
                                <button class="btn btn-outline-danger" @onclick="() => DeleteProfile(profile)" title="Delete Profile" disabled="@(profile.IsReadOnly || profile.InUse)">
                                    <span class="oi oi-trash"></span> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Confirm Delete Modal -->
@if (showDeleteConfirm && profileToDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete profile <strong>@profileToDelete.DisplayName</strong>?</p>
                    <p class="text-danger small">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">
                        <span class="oi oi-trash"></span> Delete Profile
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<SettingsProfile>? profiles;
    private List<ProfileViewModel>? filteredProfiles;
    private bool loading = true;
    private string? errorMessage;
    private string? successMessage;
    
    // Filters
    private string searchText = string.Empty;
    private string filterAlignmentMode = string.Empty;
    private string filterInUse = string.Empty;
    
    // Delete confirmation
    private bool showDeleteConfirm = false;
    private ProfileViewModel? profileToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfiles();
    }

    private async Task LoadProfiles()
    {
        try
        {
            loading = true;
            profiles = (await ProfileService.GetAllProfilesAsync()).ToList();
            await ApplyFilters();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load profiles");
            errorMessage = $"Failed to load profiles: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ApplyFilters()
    {
        if (profiles == null)
        {
            filteredProfiles = new List<ProfileViewModel>();
            return;
        }

        var query = profiles.AsEnumerable();

        // Apply search text filter
        if (!string.IsNullOrWhiteSpace(searchText))
        {
            var search = searchText.ToLower();
            query = query.Where(p => 
                p.Name.ToLower().Contains(search) || 
                p.DisplayName.ToLower().Contains(search) ||
                (p.Description?.ToLower().Contains(search) ?? false));
        }

        // Apply alignment mode filter
        if (!string.IsNullOrWhiteSpace(filterAlignmentMode))
        {
            query = query.Where(p => p.AlignmentMode.ToString() == filterAlignmentMode);
        }

        // Apply in-use filter
        if (!string.IsNullOrWhiteSpace(filterInUse))
        {
            var inUse = bool.Parse(filterInUse);
            // Note: IsProfileInUseAsync not yet implemented, will return false for now
            query = query.Where(p => false == inUse); // TODO: Implement in-use check
        }

        // Convert to view models with additional info
        var viewModels = new List<ProfileViewModel>();
        foreach (var profile in query)
        {
            var vm = new ProfileViewModel
            {
                Name = profile.Name,
                DisplayName = profile.DisplayName,
                Description = profile.Description,
                AlignmentMode = profile.AlignmentMode,
                Settings = profile.Settings,
                IsReadOnly = profile.IsReadOnly,
                LastModified = profile.LastModified,
                InUse = await ProfileService.IsProfileInUseAsync(profile.Name),
                Devices = (await ProfileService.GetDevicesUsingProfileAsync(profile.Name)).ToList()
            };
            viewModels.Add(vm);
        }

        filteredProfiles = viewModels.OrderBy(p => p.DisplayName).ToList();
    }

    private async Task FilterProfiles()
    {
        await ApplyFilters();
    }

    private async Task RefreshProfiles()
    {
        await LoadProfiles();
        successMessage = "Profiles refreshed successfully.";
    }

    private void CreateNewProfile()
    {
        Navigation.NavigateTo("/profiles/new");
    }

    private void ViewProfile(string name)
    {
        // Navigate to edit page - read-only profiles will have editing disabled
        Navigation.NavigateTo($"/profiles/{name}/edit");
    }

    private void EditProfile(string name)
    {
        Navigation.NavigateTo($"/profiles/{name}/edit");
    }

    private async Task DuplicateProfile(string name)
    {
        try
        {
            var profile = await ProfileService.GetProfileAsync(name);
            var newName = $"{name}-copy";
            var counter = 1;
            
            // Find unique name
            while (ProfileService.ProfileExists(newName))
            {
                newName = $"{name}-copy-{counter++}";
            }

            var duplicate = profile.Clone(newName);
            await ProfileService.CreateProfileAsync(duplicate.Name, duplicate.AlignmentMode, copyFromProfile: name);
            
            await LoadProfiles();
            successMessage = $"Profile duplicated as '{newName}'.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to duplicate profile {ProfileName}", name);
            errorMessage = $"Failed to duplicate profile: {ex.Message}";
        }
    }

    private async Task ExportProfile(string name)
    {
        try
        {
            // Get profile from service
            var profile = await ProfileService.GetProfileAsync(name);

            // Serialize to JSON with formatting
            var options = new JsonSerializerOptions 
            { 
                WriteIndented = true 
            };
            var json = JsonSerializer.Serialize(profile.Settings, options);

            // Convert to byte array
            var bytes = System.Text.Encoding.UTF8.GetBytes(json);
            var base64 = Convert.ToBase64String(bytes);

            // Trigger browser download using JavaScript interop
            var fileName = $"{name}.profile.json";
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "application/json", base64);

            successMessage = $"Profile '{name}' exported successfully.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to export profile {ProfileName}", name);
            errorMessage = $"Failed to export profile: {ex.Message}";
        }
    }

    private void DeleteProfile(ProfileViewModel profile)
    {
        profileToDelete = profile;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        profileToDelete = null;
        showDeleteConfirm = false;
    }

    private async Task ConfirmDelete()
    {
        if (profileToDelete == null) return;

        try
        {
            await ProfileService.DeleteProfileAsync(profileToDelete.Name);
            showDeleteConfirm = false;
            profileToDelete = null;
            await LoadProfiles();
            successMessage = "Profile deleted successfully.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete profile {ProfileName}", profileToDelete.Name);
            errorMessage = $"Failed to delete profile: {ex.Message}";
            showDeleteConfirm = false;
        }
    }

    // View model for display with computed properties
    private class ProfileViewModel
    {
        public string Name { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public string? Description { get; set; }
        public AlignmentMode AlignmentMode { get; set; }
        public SkySettings Settings { get; set; } = null!;
        public bool IsReadOnly { get; set; }
        public DateTime LastModified { get; set; }
        public bool InUse { get; set; }
        public List<int> Devices { get; set; } = new();
    }
}
