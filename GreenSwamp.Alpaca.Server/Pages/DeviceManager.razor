@page "/device-manager"
@page "/devices"
@using GreenSwamp.Alpaca.Settings.Services
@using GreenSwamp.Alpaca.Settings.Models
@using GreenSwamp.Alpaca.MountControl
@using GreenSwamp.Alpaca.Server.Services
@using SkySettings = GreenSwamp.Alpaca.Settings.Models.SkySettings
@inject IVersionedSettingsService SettingsService
@inject UnifiedDeviceRegistry DeviceRegistry
@implements IDisposable

<PageTitle>Device Manager</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Connected Devices</MudText>

@if (errorMessage != null)
{
    <MudAlert Severity="Severity.Error" ShowCloseIcon="true" CloseIconClicked="@(() => errorMessage = null)" Class="mb-3">
        @errorMessage
    </MudAlert>
}

@if (_successMessage != null)
{
    <MudAlert Severity="Severity.Success" ShowCloseIcon="true" CloseIconClicked="@(() => _successMessage = null)" Class="mb-3">
        @_successMessage
    </MudAlert>
}

@* ── Device List ──────────────────────────────────────────────────────────── *@
<MudCard Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">All Devices</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshDevices">
                Refresh
            </MudButton>
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent>
        @if (loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
        }
        else if (_devices == null || !_devices.Any())
        {
            <MudAlert Severity="Severity.Warning">
                <strong>No devices configured.</strong> Use the Add Device form below to register the first device.
            </MudAlert>
        }
        else
        {
            <MudTable Items="_devices" Hover="true" Dense="true" Striped="true">
                <HeaderContent>
                    <MudTh>Device #</MudTh>
                    <MudTh>Name</MudTh>
                    <MudTh>Mount</MudTh>
                    <MudTh>Port</MudTh>
                    <MudTh>Enabled</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{
                        var instance = MountRegistry.GetInstance(context.DeviceNumber);
                        var connected = instance?.IsConnected == true;
                    }
                    <MudTd>@context.DeviceNumber</MudTd>
                    <MudTd>@context.DeviceName</MudTd>
                    <MudTd>@context.Mount</MudTd>
                    <MudTd>@context.Port</MudTd>
                    <MudTd>
                        <MudChip T="string" Color="@(context.Enabled ? Color.Info : Color.Warning)" Size="Size.Small">
                            @(context.Enabled ? "Enabled" : "Disabled")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        @if (context.Enabled)
                        {
                            <MudChip T="string" Color="@(connected ? Color.Success : Color.Default)" Size="Size.Small">
                                @(connected ? "Connected" : "Disconnected")
                            </MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Default" Size="Size.Small">Not Loaded</MudChip>
                        }
                    </MudTd>
                    <MudTd>
                        <MudStack Row="true" Spacing="1">
                            @if (context.Enabled)
                            {
                                @if (connected)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.PowerSettingsNew"
                                               OnClick="() => Disconnect(context.DeviceNumber)">Disconnect</MudButton>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.PowerSettingsNew"
                                               OnClick="() => Connect(context.DeviceNumber)">Connect</MudButton>
                                }
                                <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Settings"
                                           Href="@($"/setup/v1/telescope/{context.DeviceNumber}/setup")" Target="_blank">Setup</MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Filled" Disabled="true" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.PowerSettingsNew">Disabled</MudButton>
                            }
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.List"
                                       Href="@($"/mountsettings/{context.DeviceNumber}")">Settings</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="() => RemoveDevice(context.DeviceNumber)">Remove</MudButton>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <MudAlert Severity="Severity.Info" Class="mt-3">
                <strong>Device Management:</strong>
                Each device has a dedicated <code>device-nn.settings.json</code> file.
                Devices with <em>Enabled: false</em> are not loaded at startup.
                Connect/Disconnect controls hardware connection per device.
            </MudAlert>
        }
    </MudCardContent>
</MudCard>

@* ── Add Device ───────────────────────────────────────────────────────────── *@
<MudCard>
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Add Device</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       OnClick="@(() => _showAddForm = !_showAddForm)">
                @(_showAddForm ? "Cancel" : "Add New Device")
            </MudButton>
        </CardHeaderActions>
    </MudCardHeader>
    @if (_showAddForm)
    {
        <MudCardContent>
            <EditForm Model="_newDevice" OnValidSubmit="AddDevice">
                <DataAnnotationsValidator />
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="2">
                        <MudNumericField T="int" @bind-Value="_newDevice.DeviceNumber" Label="Device Number" HelperText="0–99" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="_newDevice.DeviceName" Label="Device Name" Placeholder="e.g. SkyWatcher EQ6-R" />
                    </MudItem>
                    <MudItem xs="12" sm="2">
                        <MudSelect @bind-Value="_newDevice.Mount" Label="Mount Type">
                            <MudSelectItem Value="@("Simulator")">Simulator</MudSelectItem>
                            <MudSelectItem Value="@("SkyWatcher")">SkyWatcher</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="2">
                        <MudTextField @bind-Value="_newDevice.Port" Label="Serial Port" Placeholder="COM1" />
                    </MudItem>
                    <MudItem xs="12" sm="2">
                        <MudSelect @bind-Value="_newDevice.AlignmentMode" Label="Alignment Mode">
                            <MudSelectItem Value="@("GermanPolar")">German Polar</MudSelectItem>
                            <MudSelectItem Value="@("Polar")">Polar</MudSelectItem>
                            <MudSelectItem Value="@("AltAz")">Alt-Az</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
                <MudStack Row="true" Class="mt-3" AlignItems="AlignItems.Center" Spacing="2">
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                               Disabled="_adding" StartIcon="@Icons.Material.Filled.Add">
                        @if (_adding) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" /> }
                        Add Device
                    </MudButton>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        The device settings file is created immediately. Restart the application to activate the device at runtime.
                    </MudText>
                </MudStack>
            </EditForm>
        </MudCardContent>
    }
</MudCard>

@code {
    private List<SkySettings> _devices = new();
    private bool loading = true;
    private string? errorMessage;
    private string? _successMessage;
    private System.Threading.Timer? _refreshTimer;
    private long _clientId = DateTime.UtcNow.Ticks; // Unique ID for this browser session
    private bool _showAddForm;
    private NewDeviceModel _newDevice = new();
    private bool _adding;

    private class NewDeviceModel
    {
        public int DeviceNumber { get; set; }
        public string DeviceName { get; set; } = string.Empty;
        public string Mount { get; set; } = "Simulator";
        public string Port { get; set; } = "COM1";
        public string AlignmentMode { get; set; } = "GermanPolar";
    }

    protected override void OnInitialized()
    {
        LoadDevices();

        // Auto-refresh every 2 seconds to show real-time connection status
        _refreshTimer = new System.Threading.Timer(_ => 
        {
            InvokeAsync(() => 
            {
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private void LoadDevices()
    {
        try
        {
            loading = true;
            errorMessage = null;

            _devices = SettingsService.GetAllDeviceSettings();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load devices: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void RefreshDevices()
    {
        LoadDevices();
        StateHasChanged();
    }

    private void Connect(int deviceNumber)
    {
        try
        {
            var mount = MountRegistry.GetInstance(deviceNumber);
            if (mount == null)
            {
                errorMessage = $"Device {deviceNumber} not found in registry (may be disabled)";
                return;
            }

            mount.SetConnected(_clientId, true);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to connect device {deviceNumber}: {ex.Message}";
        }
    }

    private void Disconnect(int deviceNumber)
    {
        try
        {
            var instance = MountRegistry.GetInstance(deviceNumber);
            if (instance == null)
            {
                errorMessage = $"Device {deviceNumber} not found in registry";
                return;
            }

            instance.SetConnected(_clientId, false);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to disconnect device {deviceNumber}: {ex.Message}";
        }
    }

    private async Task AddDevice()
    {
        _adding = true;
        errorMessage = null;
        _successMessage = null;
        try
        {
            if (SettingsService.DeviceSettingsExist(_newDevice.DeviceNumber))
            {
                errorMessage = $"Device {_newDevice.DeviceNumber} already exists. Choose a different device number.";
                return;
            }

            // Populate full template defaults for the alignment mode (B1 behaviour)
            if (!Enum.TryParse<AlignmentMode>(_newDevice.AlignmentMode, out var alignmentMode))
                alignmentMode = AlignmentMode.GermanPolar;
            await SettingsService.CreateDeviceForModeAsync(_newDevice.DeviceNumber, _newDevice.DeviceName, alignmentMode);

            // Apply user-specified Mount and Port overrides on top of template defaults
            var settings = SettingsService.GetDeviceSettings(_newDevice.DeviceNumber) ?? new SkySettings();
            settings.Mount = _newDevice.Mount;
            settings.Port = _newDevice.Port;
            await SettingsService.SaveDeviceSettingsAsync(_newDevice.DeviceNumber, settings);

            var alpacaDevice = new AlpacaDevice
            {
                DeviceNumber = _newDevice.DeviceNumber,
                DeviceName = _newDevice.DeviceName,
                DeviceType = "Telescope",
                UniqueId = Guid.NewGuid().ToString()
            };
            await SettingsService.AddAlpacaDeviceAsync(alpacaDevice);

            _showAddForm = false;
            _newDevice = new NewDeviceModel();
            _successMessage = $"Device added. Restart the application to activate it at runtime.";
            LoadDevices();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to add device: {ex.Message}";
        }
        finally
        {
            _adding = false;
        }
    }

    private async Task RemoveDevice(int deviceNumber)
    {
        errorMessage = null;
        _successMessage = null;
        try
        {
            DeviceRegistry.RemoveDevice(deviceNumber);
            await SettingsService.RemoveAlpacaDeviceAsync(deviceNumber);
            await SettingsService.DeleteDeviceSettingsAsync(deviceNumber);

            _successMessage = $"Device {deviceNumber} removed.";
            LoadDevices();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to remove device {deviceNumber}: {ex.Message}";
        }
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
