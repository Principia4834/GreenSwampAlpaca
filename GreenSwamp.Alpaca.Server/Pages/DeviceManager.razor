@page "/device-manager"
@page "/devices"
@using GreenSwamp.Alpaca.Settings.Services
@using GreenSwamp.Alpaca.Settings.Models
@using GreenSwamp.Alpaca.MountControl
@using GreenSwamp.Alpaca.Server.Services
@using SkySettings = GreenSwamp.Alpaca.Settings.Models.SkySettings
@inject IVersionedSettingsService SettingsService
@implements IDisposable

<PageTitle>Device Manager</PageTitle>

<h3>Connected Devices</h3>

<div class="container-fluid mt-4">
    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }

    <!-- Device List Section -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">All Devices (Phase 3)</h5>
            <button class="btn btn-primary btn-sm" @onclick="RefreshDevices">
                <span class="oi oi-reload" aria-hidden="true"></span> Refresh
            </button>
        </div>
        <div class="card-body">
            @if (loading)
            {
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (_devices == null || !_devices.Any())
            {
                <div class="alert alert-warning" role="alert">
                    <strong>No devices configured.</strong>
                    <p class="mb-0">Use the Add Device form below to register the first device.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Device #</th>
                                <th>Name</th>
                                <th>Mount</th>
                                <th>Port</th>
                                <th>Enabled</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var device in _devices)
                            {
                                var instance = MountRegistry.GetInstance(device.DeviceNumber);
                                var connected = instance?.IsConnected == true;
                                var statusBadge = connected ? "badge bg-success" : "badge bg-secondary";
                                var statusText = connected ? "Connected" : "Disconnected";
                                var enabledBadge = device.Enabled ? "badge bg-info" : "badge bg-warning";

                                <tr class="@(device.Enabled ? "" : "table-secondary")">
                                    <td>@device.DeviceNumber</td>
                                    <td>@device.DeviceName</td>
                                    <td>@device.Mount</td>
                                    <td>@device.Port</td>
                                    <td>
                                        <span class="@enabledBadge">@(device.Enabled ? "Enabled" : "Disabled")</span>
                                    </td>
                                    <td>
                                        @if (device.Enabled)
                                        {
                                            <span class="@statusBadge">@statusText</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Not Loaded</span>
                                        }
                                    </td>
                                    <td>
                                        @if (device.Enabled)
                                        {
                                            @if (connected)
                                            {
                                                <button class="btn btn-danger btn-sm me-1" @onclick="() => Disconnect(device.DeviceNumber)" title="Disconnect this device">
                                                    <span class="oi oi-power-standby" aria-hidden="true"></span> Disconnect
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-primary btn-sm me-1" @onclick="() => Connect(device.DeviceNumber)" title="Connect this device">
                                                    <span class="oi oi-power-standby" aria-hidden="true"></span> Connect
                                                </button>
                                            }
                                            <a href="/setup/v1/telescope/@device.DeviceNumber/setup" class="btn btn-info btn-sm me-1" target="_blank" title="Open ASCOM device setup page">
                                                <span class="oi oi-cog" aria-hidden="true"></span> Setup
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary btn-sm me-1" disabled title="Device disabled in settings">
                                                <span class="oi oi-power-standby" aria-hidden="true"></span> Disabled
                                            </button>
                                        }
                                        <a href="/mountsettings/@device.DeviceNumber" class="btn btn-outline-secondary btn-sm me-1" title="Edit mount settings for device @device.DeviceNumber">
                                            <span class="oi oi-list" aria-hidden="true"></span> Settings
                                        </a>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveDevice(device.DeviceNumber)" title="Remove device @device.DeviceNumber">
                                            <span class="oi oi-trash" aria-hidden="true"></span> Remove
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="alert alert-info mt-3" role="alert">
                    <strong>Device Management:</strong>
                    <ul class="mb-0">
                        <li>Each device has a dedicated <code>device-nn.settings.json</code> settings file</li>
                        <li>Devices with <code>Enabled: false</code> are not loaded at startup</li>
                        <li>Use the Add Device form below to register new devices (restart required to activate)</li>
                        <li>Connect/Disconnect controls mount hardware connection per device</li>
                    </ul>
                </div>
            }
        </div>
    </div>
</div>

@if (_successMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        @_successMessage
        <button type="button" class="btn-close" @onclick="@(() => _successMessage = null)"></button>
    </div>
}

<div class="card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Add Device</h5>
        <button class="btn btn-outline-primary btn-sm" @onclick="@(() => _showAddForm = !_showAddForm)">
            @(_showAddForm ? "Cancel" : "Add New Device")
        </button>
    </div>
    @if (_showAddForm)
    {
        <div class="card-body">
            <EditForm Model="_newDevice" OnValidSubmit="AddDevice">
                <DataAnnotationsValidator />
                <div class="row g-3">
                    <div class="col-md-2">
                        <label class="form-label">Device Number</label>
                        <InputNumber @bind-Value="_newDevice.DeviceNumber" class="form-control" />
                        <small class="form-text text-muted">0–99</small>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Device Name</label>
                        <InputText @bind-Value="_newDevice.DeviceName" class="form-control" placeholder="e.g. SkyWatcher EQ6-R" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Mount Type</label>
                        <InputSelect @bind-Value="_newDevice.Mount" class="form-select">
                            <option value="Simulator">Simulator</option>
                            <option value="SkyWatcher">SkyWatcher</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Serial Port</label>
                        <InputText @bind-Value="_newDevice.Port" class="form-control" placeholder="COM1" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Alignment Mode</label>
                        <InputSelect @bind-Value="_newDevice.AlignmentMode" class="form-select">
                            <option value="GermanPolar">German Polar</option>
                            <option value="Polar">Polar</option>
                            <option value="AltAz">Alt-Az</option>
                        </InputSelect>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary" disabled="@_adding">
                        @if (_adding) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        Add Device
                    </button>
                </div>
                <p class="text-muted mt-2 mb-0">
                    <small>The device settings file is created immediately. Restart the application to activate the device at runtime.</small>
                </p>
            </EditForm>
        </div>
    }
</div>

@code {
    private List<SkySettings> _devices = new();
    private bool loading = true;
    private string? errorMessage;
    private string? _successMessage;
    private System.Threading.Timer? _refreshTimer;
    private long _clientId = DateTime.UtcNow.Ticks; // Unique ID for this browser session
    private bool _showAddForm;
    private NewDeviceModel _newDevice = new();
    private bool _adding;

    private class NewDeviceModel
    {
        public int DeviceNumber { get; set; }
        public string DeviceName { get; set; } = string.Empty;
        public string Mount { get; set; } = "Simulator";
        public string Port { get; set; } = "COM1";
        public string AlignmentMode { get; set; } = "GermanPolar";
    }

    protected override void OnInitialized()
    {
        LoadDevices();

        // Auto-refresh every 2 seconds to show real-time connection status
        _refreshTimer = new System.Threading.Timer(_ => 
        {
            InvokeAsync(() => 
            {
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private void LoadDevices()
    {
        try
        {
            loading = true;
            errorMessage = null;

            _devices = SettingsService.GetAllDeviceSettings();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load devices: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void RefreshDevices()
    {
        LoadDevices();
        StateHasChanged();
    }

    private void Connect(int deviceNumber)
    {
        try
        {
            var instance = MountRegistry.GetInstance(deviceNumber);
            if (instance == null)
            {
                errorMessage = $"Device {deviceNumber} not found in registry (may be disabled)";
                return;
            }

            instance.SetConnected(_clientId, true);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to connect device {deviceNumber}: {ex.Message}";
        }
    }

    private void Disconnect(int deviceNumber)
    {
        try
        {
            var instance = MountRegistry.GetInstance(deviceNumber);
            if (instance == null)
            {
                errorMessage = $"Device {deviceNumber} not found in registry";
                return;
            }

            instance.SetConnected(_clientId, false);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to disconnect device {deviceNumber}: {ex.Message}";
        }
    }

    private async Task AddDevice()
    {
        _adding = true;
        errorMessage = null;
        _successMessage = null;
        try
        {
            if (SettingsService.DeviceSettingsExist(_newDevice.DeviceNumber))
            {
                errorMessage = $"Device {_newDevice.DeviceNumber} already exists. Choose a different device number.";
                return;
            }

            // Populate full template defaults for the alignment mode (B1 behaviour)
            if (!Enum.TryParse<AlignmentMode>(_newDevice.AlignmentMode, out var alignmentMode))
                alignmentMode = AlignmentMode.GermanPolar;
            await SettingsService.CreateDeviceForModeAsync(_newDevice.DeviceNumber, _newDevice.DeviceName, alignmentMode);

            // Apply user-specified Mount and Port overrides on top of template defaults
            var settings = SettingsService.GetDeviceSettings(_newDevice.DeviceNumber) ?? new SkySettings();
            settings.Mount = _newDevice.Mount;
            settings.Port = _newDevice.Port;
            await SettingsService.SaveDeviceSettingsAsync(_newDevice.DeviceNumber, settings);

            var alpacaDevice = new AlpacaDevice
            {
                DeviceNumber = _newDevice.DeviceNumber,
                DeviceName = _newDevice.DeviceName,
                DeviceType = "Telescope",
                UniqueId = Guid.NewGuid().ToString()
            };
            await SettingsService.AddAlpacaDeviceAsync(alpacaDevice);

            _showAddForm = false;
            _newDevice = new NewDeviceModel();
            _successMessage = $"Device added. Restart the application to activate it at runtime.";
            LoadDevices();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to add device: {ex.Message}";
        }
        finally
        {
            _adding = false;
        }
    }

    private async Task RemoveDevice(int deviceNumber)
    {
        errorMessage = null;
        _successMessage = null;
        try
        {
            UnifiedDeviceRegistry.RemoveDevice(deviceNumber);
            await SettingsService.RemoveAlpacaDeviceAsync(deviceNumber);
            await SettingsService.DeleteDeviceSettingsAsync(deviceNumber);

            _successMessage = $"Device {deviceNumber} removed.";
            LoadDevices();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to remove device {deviceNumber}: {ex.Message}";
        }
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
