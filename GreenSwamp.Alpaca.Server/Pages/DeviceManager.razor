@page "/device-manager"
@page "/devices"
@using GreenSwamp.Alpaca.Settings.Services
@using GreenSwamp.Alpaca.Settings.Models
@using GreenSwamp.Alpaca.MountControl
@inject IVersionedSettingsService SettingsService
@implements IDisposable

<PageTitle>Device Manager</PageTitle>

<h3>Connected Devices</h3>

<div class="container-fluid mt-4">
    @if (errorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="@(() => errorMessage = null)"></button>
        </div>
    }

    <!-- Device List Section -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">All Devices (Phase 3)</h5>
            <button class="btn btn-primary btn-sm" @onclick="RefreshDevices">
                <span class="oi oi-reload" aria-hidden="true"></span> Refresh
            </button>
        </div>
        <div class="card-body">
            @if (loading)
            {
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (_devices == null || !_devices.Any())
            {
                <div class="alert alert-warning" role="alert">
                    <strong>No devices configured.</strong>
                    <p class="mb-0">
                        Devices are loaded from <code>appsettings.user.json</code> Devices array.
                        Edit the settings file and restart the application to add devices.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Device #</th>
                                <th>Name</th>
                                <th>Mount</th>
                                <th>Port</th>
                                <th>Enabled</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var device in _devices)
                            {
                                var instance = MountInstanceRegistry.GetInstance(device.DeviceNumber);
                                var connected = instance?.IsConnected == true;
                                var statusBadge = connected ? "badge bg-success" : "badge bg-secondary";
                                var statusText = connected ? "Connected" : "Disconnected";
                                var enabledBadge = device.Enabled ? "badge bg-info" : "badge bg-warning";

                                <tr class="@(device.Enabled ? "" : "table-secondary")">
                                    <td>@device.DeviceNumber</td>
                                    <td>@device.DeviceName</td>
                                    <td>@device.Mount</td>
                                    <td>@device.Port</td>
                                    <td>
                                        <span class="@enabledBadge">@(device.Enabled ? "Enabled" : "Disabled")</span>
                                    </td>
                                    <td>
                                        @if (device.Enabled)
                                        {
                                            <span class="@statusBadge">@statusText</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Not Loaded</span>
                                        }
                                    </td>
                                    <td>
                                        @if (device.Enabled)
                                        {
                                            @if (connected)
                                            {
                                                <button class="btn btn-danger btn-sm" @onclick="() => Disconnect(device.DeviceNumber)" title="Disconnect this device">
                                                    <span class="oi oi-power-standby" aria-hidden="true"></span> Disconnect
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-primary btn-sm" @onclick="() => Connect(device.DeviceNumber)" title="Connect this device">
                                                    <span class="oi oi-power-standby" aria-hidden="true"></span> Connect
                                                </button>
                                            }
                                            <a href="/setup/v1/telescope/@device.DeviceNumber/setup" class="btn btn-info btn-sm" target="_blank" title="Open device setup page">
                                                <span class="oi oi-cog" aria-hidden="true"></span> Setup
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary btn-sm" disabled title="Device disabled in settings">
                                                <span class="oi oi-power-standby" aria-hidden="true"></span> Disabled
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="alert alert-info mt-3" role="alert">
                    <strong>Phase 3 Settings-First Architecture:</strong>
                    <ul class="mb-0">
                        <li>Each device has all 137 settings properties (Port, BaudRate, Latitude, etc.)</li>
                        <li>Devices with <code>Enabled: false</code> are not loaded at startup</li>
                        <li>Edit <code>appsettings.user.json</code> to add/remove devices (requires restart)</li>
                        <li>Connect/Disconnect controls mount hardware connection per device</li>
                    </ul>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<SkySettings> _devices = new();
    private bool loading = true;
    private string? errorMessage;
    private System.Threading.Timer? _refreshTimer;
    private long _clientId = DateTime.UtcNow.Ticks; // Unique ID for this browser session

    protected override void OnInitialized()
    {
        LoadDevices();

        // Auto-refresh every 2 seconds to show real-time connection status
        _refreshTimer = new System.Threading.Timer(_ => 
        {
            InvokeAsync(() => 
            {
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private void LoadDevices()
    {
        try
        {
            loading = true;
            errorMessage = null;

            _devices = SettingsService.GetAllDevices();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load devices: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void RefreshDevices()
    {
        LoadDevices();
        StateHasChanged();
    }

    private void Connect(int deviceNumber)
    {
        try
        {
            var instance = MountInstanceRegistry.GetInstance(deviceNumber);
            if (instance == null)
            {
                errorMessage = $"Device {deviceNumber} not found in registry (may be disabled)";
                return;
            }

            instance.SetConnected(_clientId, true);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to connect device {deviceNumber}: {ex.Message}";
        }
    }

    private void Disconnect(int deviceNumber)
    {
        try
        {
            var instance = MountInstanceRegistry.GetInstance(deviceNumber);
            if (instance == null)
            {
                errorMessage = $"Device {deviceNumber} not found in registry";
                return;
            }

            instance.SetConnected(_clientId, false);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to disconnect device {deviceNumber}: {ex.Message}";
        }
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
