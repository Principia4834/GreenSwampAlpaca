<?xml version="1.0" encoding="utf-8"?>
<!-- https://go.microsoft.com/fwlink/?LinkID=208121 -->
<Project>
  <PropertyGroup>
	<DeleteExistingFiles>true</DeleteExistingFiles>
	<ExcludeApp_Data>false</ExcludeApp_Data>
	<LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
	<LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
	<LastUsedPlatform>Any CPU</LastUsedPlatform>
	<PublishProvider>FileSystem</PublishProvider>
	<PublishUrl>..\publish\win-x86\</PublishUrl>
	<PublishDir>..\publish\win-x86\</PublishDir>
	<WebPublishMethod>FileSystem</WebPublishMethod>
	<TargetFramework>net10.0</TargetFramework>
	<SelfContained>false</SelfContained>
	<RuntimeIdentifier>win-x86</RuntimeIdentifier>
	<PublishSingleFile>true</PublishSingleFile>
	<PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>

	<Target Name="ExcludeXmlAndPdbFiles" AfterTargets="ComputeFilesToPublish">
		<ItemGroup>
			<ResolvedFileToPublish Remove="@(ResolvedFileToPublish)"
			                       Condition="'%(ResolvedFileToPublish.Extension)' == '.xml'
                                     And '%(ResolvedFileToPublish.Filename)' != 'ASCOM.Common'
                                     And '%(ResolvedFileToPublish.Filename)' != 'ASCOM.Alpaca.Razor'
                                     And '%(ResolvedFileToPublish.Filename)' != 'GreenSwamp.Alpaca.Server'" />
			<ResolvedFileToPublish Remove="@(ResolvedFileToPublish)"
			                       Condition="'%(ResolvedFileToPublish.Extension)' == '.pdb'" />
		</ItemGroup>
	</Target>
</Project>
