@using GreenSwamp.Alpaca.Settings.Models

@* Combined editor: Tracking + Pulse Guiding *@

<MudExpansionPanels MultiExpansion="true">

    <MudExpansionPanel Text="Tracking" Icon="@Icons.Material.Filled.Speed" Expanded="false">
        <MudStack Spacing="3">
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Start tracking automatically when the mount unparks." Placement="Placement.Right" Arrow="true">
                <MudCheckBox @bind-Value="Device!.TrackAfterUnpark" @bind-Value:after="NotifyChanged"
                             Label="Track After Unpark" Color="Color.Primary" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Default tracking rate (Sidereal, Lunar, Solar, King)." Placement="Placement.Right" Arrow="true">
                <MudSelect T="string" @bind-Value="Device!.TrackingRate" @bind-Value:after="NotifyChanged"
                           Label="Tracking Rate">
                    <MudSelectItem Value="@("Sidereal")">Sidereal</MudSelectItem>
                    <MudSelectItem Value="@("Lunar")">Lunar</MudSelectItem>
                    <MudSelectItem Value="@("Solar")">Solar</MudSelectItem>
                    <MudSelectItem Value="@("King")">King</MudSelectItem>
                </MudSelect>
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Sidereal tracking rate in arcseconds/second." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.SiderealRate" @bind-Value:after="NotifyChanged"
                                 Label="Sidereal Rate (arcsec/s)" Format="F6" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Lunar tracking rate in arcseconds/second." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.LunarRate" @bind-Value:after="NotifyChanged"
                                 Label="Lunar Rate (arcsec/s)" Format="F6" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Solar tracking rate in arcseconds/second." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.SolarRate" @bind-Value:after="NotifyChanged"
                                 Label="Solar Rate (arcsec/s)" Format="F6" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="King tracking rate in arcseconds/second." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="double" @bind-Value="Device!.KingRate" @bind-Value:after="NotifyChanged"
                                 Label="King Rate (arcsec/s)" Format="F6" Immediate="true" />
            </MudTooltip>
            @if (ShowHidden)
            {
                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="RA axis tracking offset in motor steps." Placement="Placement.Right" Arrow="true">
                    <MudNumericField T="int" @bind-Value="Device!.RATrackingOffset" @bind-Value:after="NotifyChanged"
                                     Label="RA Tracking Offset (steps)" Immediate="true" />
                </MudTooltip>
            }
            @if (ShowHidden)
            {
                <MudTooltip Inline="false" RootStyle="max-width:260px" Text="AltAz tracking update interval in milliseconds." Placement="Placement.Right" Arrow="true">
                    <MudNumericField T="int" @bind-Value="Device!.AltAzTrackingUpdateInterval" @bind-Value:after="NotifyChanged"
                                     Label="AltAz Update Interval (ms)" Immediate="true" />
                </MudTooltip>
            }
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Pulse Guiding" Icon="@Icons.Material.Filled.NearMe">
        <MudStack Spacing="3">
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Minimum RA pulse duration in milliseconds." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="int" @bind-Value="Device!.MinPulseRa" @bind-Value:after="NotifyChanged"
                                 Label="Min Pulse RA (ms)" Min="5" Max="50" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Minimum Dec pulse duration in milliseconds." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="int" @bind-Value="Device!.MinPulseDec" @bind-Value:after="NotifyChanged"
                                 Label="Min Pulse Dec (ms)" Min="5" Max="50" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Route Dec pulse commands via GoTo instead of pulse guiding." Placement="Placement.Right" Arrow="true">
                <MudCheckBox @bind-Value="Device!.DecPulseToGoTo" @bind-Value:after="NotifyChanged"
                             Label="Dec Pulse → GoTo" Color="Color.Primary" />
            </MudTooltip>
            <MudCheckBox @bind-Value="Device!.AlternatingPPEC" @bind-Value:after="NotifyChanged"
                         Label="Alternating PPEC" Color="Color.Primary" />
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="ST4 guide rate divisor (e.g. 0=full, 1=0.75x, 2=0.5x, etc.)." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="int" @bind-Value="Device!.St4Guiderate" @bind-Value:after="NotifyChanged"
                                 Label="ST4 Guide Rate" Min="0" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="RA guide rate as a percentage of sidereal (0–100, step 10)." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="int" @bind-Value="_raGuideRatePercent" @bind-Value:after="OnRaGuideRateChanged"
                                 Label="RA Guiding Rate %" Min="0" Max="100" Step="10" Immediate="true" />
            </MudTooltip>
            <MudTooltip Inline="false" RootStyle="max-width:260px" Text="Dec guide rate as a percentage of sidereal (0–100, step 10)." Placement="Placement.Right" Arrow="true">
                <MudNumericField T="int" @bind-Value="_decGuideRatePercent" @bind-Value:after="OnDecGuideRateChanged"
                                 Label="Dec Guiding Rate %" Min="0" Max="100" Step="10" Immediate="true" />
            </MudTooltip>
        </MudStack>
    </MudExpansionPanel>

</MudExpansionPanels>

@code {
    [Parameter] public SkySettings? Device { get; set; }
    [Parameter] public bool ShowHidden { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private bool _initialized;
    private bool _parametersChanging;
    private int _raGuideRatePercent;
    private int _decGuideRatePercent;

    protected override void OnParametersSet()
    {
        _parametersChanging = true;
        _raGuideRatePercent = (int)Math.Round((Device?.GuideRateOffsetX ?? 0.0) * 100);
        _decGuideRatePercent = (int)Math.Round((Device?.GuideRateOffsetY ?? 0.0) * 100);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender) _initialized = true;
        _parametersChanging = false;
    }

    // Guard against MudNumericField firing ValueChanged during initial render or
    // parameter-change re-render (Min/Max coercion causing a false IsDirty on reset).
    private async Task NotifyChanged()
    {
        if (!_initialized || _parametersChanging) return;
        await OnChanged.InvokeAsync();
    }

    private async Task OnRaGuideRateChanged()
    {
        Device!.GuideRateOffsetX = _raGuideRatePercent / 100.0;
        await NotifyChanged();
    }

    private async Task OnDecGuideRateChanged()
    {
        Device!.GuideRateOffsetY = _decGuideRatePercent / 100.0;
        await NotifyChanged();
    }
}