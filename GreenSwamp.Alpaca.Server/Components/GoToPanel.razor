@using GreenSwamp.Alpaca.MountControl
@using GreenSwamp.Alpaca.Server.Services
@inject ISnackbar Snackbar
@inject TelescopeStateService StateService
@inject IDialogService DialogService

<fieldset disabled="@(!IsEnabled)" style="border:none;padding:0;margin:0">
<MudStack Spacing="3" Class="mt-1">

    @* Action buttons (left) + coordinate fields (right) *@
    <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start">

        @* Left column: GoTo / Copy / Sync *@
        <MudStack Spacing="4" Style="min-width:72px">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       FullWidth="true"
                       Disabled="@(!IsEnabled)"
                       OnClick="OnGoTo">GoTo</MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       FullWidth="true"
                       Disabled="@(!IsEnabled)"
                       OnClick="OnCopy">Copy</MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       FullWidth="true"
                       Disabled="@(!IsEnabled|| _coordMode != CoordMode.RaDec || !_canSync)"
                       OnClick="OnSync">Sync</MudButton>
        </MudStack>

        @* Right: coordinate entry fields *@
        <MudStack Spacing="2" Style="min-width:320px">
            @if (_entryMode == EntryMode.Float)
            {
                @if (_coordMode == CoordMode.RaDec)
                {
                    <MudNumericField T="double" @bind-Value="_raFloat"
                                    Disabled="@(!IsEnabled)"
                                    Label="RA (h)" Format="F4"
                                    Min="0.0" Max="23.9999" Immediate="true" />
                    <MudNumericField T="double" @bind-Value="_decFloat"
                                    Disabled="@(!IsEnabled)"
                                    Label="Dec (°)" Format="F4"
                                    Min="-90.0" Max="90.0" Immediate="true" />
                }
                else
                {
                    <MudNumericField T="double" @bind-Value="_azFloat"
                                    Disabled="@(!IsEnabled)"
                                    Label="Az (°)" Format="F4"
                                    Min="0.0" Max="359.999" Immediate="true" />
                    <MudNumericField T="double" @bind-Value="_altFloat"
                                    Label="Alt (°)" Format="F4"
                                    Min="@_horizonLimit" Max="90.0" Immediate="true" />
                }
            }
            else
            {
                @if (_coordMode == CoordMode.RaDec)
                {
                    @* RA: hours [0..23], minutes [0..59], seconds [0..59.99] *@
                    <MudStack Row="true" AlignItems="AlignItems.End" Spacing="1">
                        <MudNumericField T="int" @bind-Value="_raH" Label="RA hours"
                                    Disabled="@(!IsEnabled)"
                                    Min="0" Max="23" Immediate="true" Style="width:80px" />
                        <MudNumericField T="int" @bind-Value="_raM" Label="minutes"
                                    Disabled="@(!IsEnabled)"
                                    Min="0" Max="59" Immediate="true" Style="width:68px" />
                        <MudNumericField T="double" @bind-Value="_raS" Label="seconds"
                                    Disabled="@(!IsEnabled)"
                                    Min="0.0" Max="59.99" Format="F2" Immediate="true" Style="width:80px" />
                    </MudStack>
                    @* Dec: degrees [-90..90], minutes [0..59], seconds [0..59.99] *@
                    <MudStack Row="true" AlignItems="AlignItems.End" Spacing="1">
                        <MudNumericField T="int" @bind-Value="_decD" Label="Dec degrees"
                                    Disabled="@(!IsEnabled)"
                                    Min="-90" Max="90" Immediate="true" Style="width:80px" />
                        <MudNumericField T="int" @bind-Value="_decM" Label="minutes"
                                    Disabled="@(!IsEnabled)"
                                    Min="0" Max="59" Immediate="true" Style="width:68px" />
                        <MudNumericField T="double" @bind-Value="_decS" Label="seconds"
                                    Disabled="@(!IsEnabled)"
                                    Min="0.0" Max="59.99" Format="F2" Immediate="true" Style="width:80px" />
                    </MudStack>
                }
                else
                {
                    @* Az: degrees [0..359], minutes [0..59], seconds [0..59.99] *@
                    <MudStack Row="true" AlignItems="AlignItems.End" Spacing="1">
                        <MudNumericField T="int" @bind-Value="_azD" Label="Az degrees"
                                    Disabled="@(!IsEnabled)"
                                    Min="0" Max="359" Immediate="true" Style="width:80px" />
                        <MudNumericField T="int" @bind-Value="_azM" Label="minutes"
                                    Disabled="@(!IsEnabled)"
                                    Min="0" Max="59" Immediate="true" Style="width:68px" />
                        <MudNumericField T="double" @bind-Value="_azS" Label="seconds"
                                    Disabled="@(!IsEnabled)"
                                    Min="0.0" Max="59.99" Format="F2" Immediate="true" Style="width:80px" />
                    </MudStack>
                    @* Alt: degrees [HorizonLimit..90], minutes [0..59], seconds [0..59.99] *@
                    <MudStack Row="true" AlignItems="AlignItems.End" Spacing="1">
                        <MudNumericField T="int" @bind-Value="_altD" Label="Alt degrees"
                                    Disabled="@(!IsEnabled)"
                                    Min="@_altDMin" Max="90" Immediate="true" Style="width:80px" />
                        <MudNumericField T="int" @bind-Value="_altM" Label="minutes"
                                    Disabled="@(!IsEnabled)"
                                    Min="0" Max="59" Immediate="true" Style="width:68px" />
                        <MudNumericField T="double" @bind-Value="_altS" Label="seconds"
                                    Disabled="@(!IsEnabled)"
                                    Min="0.0" Max="59.99" Format="F2" Immediate="true" Style="width:80px" />
                    </MudStack>
                }
            }
        </MudStack>
    </MudStack>

    @* Coordinate system + entry format selectors *@
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
        <MudToggleGroup T="CoordMode" @bind-Value="_coordMode" Size="Size.Small" Color="Color.Primary"
                        SelectionMode="SelectionMode.SingleSelection"
                        Disabled="@(!IsEnabled)">
            <MudToggleItem Value="CoordMode.RaDec" Text="RA / Dec" />
            <MudToggleItem Value="CoordMode.AltAz" Text="Alt / Az" />
        </MudToggleGroup>
        <MudToggleGroup T="EntryMode" Value="_entryMode" ValueChanged="OnEntryModeChanged"
                        Size="Size.Small" Color="Color.Primary"
                        SelectionMode="SelectionMode.SingleSelection"
                        Disabled="@(!IsEnabled)">
            <MudToggleItem Value="EntryMode.HmsDms" Text="HMS / DMS" />
            <MudToggleItem Value="EntryMode.Float" Text="Float" />
        </MudToggleGroup>
    </MudStack>

</MudStack>
</fieldset>
