<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.FlipCameraAndroid" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Flip Side of Pier</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="mt-2">
            <MudText Typo="Typo.body2">
                The mount will slew to the same sky position on the opposite pier side.
                The telescope must be within the flip angle limits.
            </MudText>
            <MudDivider />
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudSwitch T="bool" @bind-Value="_flipOnNextGoto" Color="Color.Secondary"
                           Label="Flip on next GoTo" />
            </MudStack>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                When enabled, the next GoTo slew will cross the meridian before tracking.
            </MudText>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AcceptFlip">Flip Now</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Current value of the FlipOnNextGoto flag, passed in from the parent.</summary>
    [Parameter] public bool FlipOnNextGoto { get; set; }

    private bool _flipOnNextGoto;

    protected override void OnParametersSet() => _flipOnNextGoto = FlipOnNextGoto;

    private void AcceptFlip() =>
        MudDialog.Close(DialogResult.Ok(new FlipSopResult(true, _flipOnNextGoto)));

    private void Cancel() =>
        MudDialog.Close(DialogResult.Ok(new FlipSopResult(false, _flipOnNextGoto)));

    public record FlipSopResult(bool DoFlip, bool FlipOnNextGoto);
}
